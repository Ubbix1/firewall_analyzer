# --- Firewall Analyzer Server Configuration ---

# The secret token used to sign/verify WebSocket requests
# MUST match the APP_ACCESS_TOKEN used when building the Flutter app
PACKET_ANALYZER_TOKEN=your_random_secure_token_here

# Telegram Bot Configuration for Alerts & Remote Control
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_personal_chat_id_here
PACKET_ANALYZER_TELEGRAM_PIN=1234

# Notification Settings
THREAT_NOTIFICATION_COOLDOWN_SECONDS=3600
AUTO_BLOCK_THREATS=false
