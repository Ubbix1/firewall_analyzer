<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/docker_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E2E"
    android:clickable="true"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- TOP ROW: Label + Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🐳 DOCKER"
            android:textColor="#88FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● OFFLINE"
            android:textColor="#FF5252"
            android:textSize="8sp"
            android:textStyle="bold"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />
    </LinearLayout>

    <!-- DIVIDER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp"
        android:background="#22FFFFFF" />

    <!-- HERO: Container Count -->
    <TextView
        android:id="@+id/widget_docker_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0/0"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Running Containers"
        android:textColor="#66FFFFFF"
        android:textSize="9sp"
        android:layout_marginTop="2dp" />

    <!-- SPACER -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- BOTTOM: Health -->
    <TextView
        android:id="@+id/widget_docker_health"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Waiting for data..."
        android:textColor="#81C784"
        android:textSize="10sp" />

</LinearLayout>
